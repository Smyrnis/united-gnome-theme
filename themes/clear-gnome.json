{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "Dark Gnome",
    "author": "Giannis Smyrnis",
    "themes": [
        {
            "name": "Dark Gnome",
            "appearance": "dark",
            "style": {
                "accents": [
                    "#4285F4",
                    "#EA4335",
                    "#FBBC04",
                    "#34A853",
                    "#A142F4",
                    "#24C1E0"
                ],

                "background": "#202124",
                "surface.background": "#202124",
                "elevated_surface.background": "#292a2d",
                "panel.background": "#292a2d",
                "panel.focused_border": "#4285F4",

                "border": "#00000000",
                "border.variant": "#00000000",
                "border.focused": "#4285F4",
                "border.selected": "#4285F4",
                "border.transparent": "#00000000",
                "border.disabled": "#00000000",

                "text": "#E8EAED",
                "text.muted": "#9AA0A6",
                "text.placeholder": "#5f6368",
                "text.disabled": "#3c4043",
                "text.accent": "#FFFFFF",

                "icon": "#E8EAED",
                "icon.muted": "#5f6368",
                "icon.disabled": "#3c4043",
                "icon.placeholder": "#5f6368",
                "icon.accent": "#FFFFFF",

                "element.background": "#35363a",
                "element.hover": "#2d2e31",
                "element.active": "#4285F460",
                "element.selected": "#4285F460",
                "element.disabled": "#2d2e31",

                "ghost_element.background": "#00000000",
                "ghost_element.hover": "#ffffff10",
                "ghost_element.active": "#4285F430",
                "ghost_element.selected": "#4285F460",
                "ghost_element.disabled": "#00000000",

                "drop_target.background": "#2d2e31",

                "tab_bar.background": "#171717",
                "tab.inactive_background": "#202124",
                "tab.active_background": "#292a2d",

                "toolbar.background": "#292a2d",
                "status_bar.background": "#171717",
                "title_bar.background": "#171717",
                "title_bar.inactive_background": "#171717",

                "scrollbar.track.background": "#00000000",
                "scrollbar.track.border": "#00000000",
                "scrollbar.thumb.background": "#5f636880",
                "scrollbar.thumb.hover_background": "#80868B",
                "scrollbar.thumb.border": "#00000000",

                "editor.background": "#202124",
                "editor.foreground": "#E8EAED",
                "editor.gutter.background": "#202124",
                "editor.subheader.background": "#292a2d",
                "editor.active_line.background": "#ffffff08",
                "editor.highlighted_line.background": "#ffffff08",
                "editor.line_number": "#5f6368",
                "editor.active_line_number": "#E8EAED",
                "editor.indent_guide": "#35363a",
                "editor.indent_guide_active": "#5f6368",
                "editor.invisible": "#35363a",
                "editor.wrap_guide": "#35363a",
                "editor.active_wrap_guide": "#5f6368",
                "editor.document_highlight.read_background": "#5f636820",
                "editor.document_highlight.write_background": "#5f636820",

                "search.match_background": "#FBBC0460",
                "link_text.hover": "#8AB4F8",

                "terminal.background": "#202124",
                "terminal.foreground": "#E8EAED",
                "terminal.bright_foreground": "#FFFFFF",
                "terminal.dim_foreground": "#9AA0A6",

                "terminal.ansi.black": "#000000",
                "terminal.ansi.red": "#EA4335",
                "terminal.ansi.green": "#34A853",
                "terminal.ansi.yellow": "#FBBC04",
                "terminal.ansi.blue": "#4285F4",
                "terminal.ansi.magenta": "#A142F4",
                "terminal.ansi.cyan": "#24C1E0",
                "terminal.ansi.white": "#E8EAED",

                "terminal.ansi.bright_black": "#5f6368",
                "terminal.ansi.bright_red": "#F28B82",
                "terminal.ansi.bright_green": "#81C995",
                "terminal.ansi.bright_yellow": "#FDD663",
                "terminal.ansi.bright_blue": "#8AB4F8",
                "terminal.ansi.bright_magenta": "#C58AF9",
                "terminal.ansi.bright_cyan": "#78D9EC",
                "terminal.ansi.bright_white": "#FFFFFF",

                "terminal.ansi.dim_black": "#000000",
                "terminal.ansi.dim_red": "#c5221f",
                "terminal.ansi.dim_green": "#188038",
                "terminal.ansi.dim_yellow": "#F29900",
                "terminal.ansi.dim_blue": "#1967D2",
                "terminal.ansi.dim_magenta": "#7627BB",
                "terminal.ansi.dim_cyan": "#129EAF",
                "terminal.ansi.dim_white": "#9AA0A6",

                "conflict": "#FBBC04",
                "conflict.background": "#FBBC0420",
                "conflict.border": "#FBBC0460",

                "created": "#34A853",
                "created.background": "#34A85320",
                "created.border": "#34A85360",

                "deleted": "#EA4335",
                "deleted.background": "#EA433520",
                "deleted.border": "#EA433560",

                "modified": "#F29900",
                "modified.background": "#F2990020",
                "modified.border": "#F2990060",

                "renamed": "#4285F4",
                "renamed.background": "#4285F420",
                "renamed.border": "#4285F460",

                "ignored": "#5f6368",
                "ignored.background": "#5f636820",
                "ignored.border": "#5f636840",

                "hidden": "#5f6368",
                "hidden.background": "#5f636820",
                "hidden.border": "#5f636840",

                "error": "#EA4335",
                "error.background": "#35363a",
                "error.border": "#EA4335",

                "warning": "#F29900",
                "warning.background": "#35363a",
                "warning.border": "#F29900",

                "info": "#4285F4",
                "info.background": "#35363a",
                "info.border": "#4285F4",

                "success": "#34A853",
                "success.background": "#35363a",
                "success.border": "#34A853",

                "hint": "#8AB4F8",
                "hint.background": "#35363a",
                "hint.border": "#8AB4F8",

                "players": [
                    {
                        "cursor": "#4285F4",
                        "background": "#EA433573",
                        "selection": "#4a4a4a"
                    }
                ],

                "syntax": {
                    "keyword": { "color": "#C58AF9", "font_weight": 700 },
                    "keyword.control": {
                        "color": "#A142F4",
                        "font_weight": 700
                    },

                    "function": { "color": "#8AB4F8" },
                    "function.method": { "color": "#78A6F6" },

                    "type": { "color": "#FBBC04" },
                    "type.builtin": { "color": "#FDD663" },

                    "string": { "color": "#81C995" },
                    "string.escape": { "color": "#FDD663" },

                    "number": { "color": "#F28B82" },
                    "constant": { "color": "#81C995" },

                    "variable": { "color": "#E8EAED" },
                    "variable.parameter": { "color": "#AECBFA" },
                    "variable.member": { "color": "#8AB4F8" },

                    "operator": { "color": "#9AA0A6" },

                    "comment": { "color": "#8F8F8FFF", "font_style": "normal" },
                    "comment.doc": {
                        "color": "#7F848AFF",
                        "font_style": "normal"
                    },

                    "punctuation": { "color": "#9AA0A6" },
                    "punctuation.bracket": { "color": "#BDC1C6" },
                    "punctuation.delimiter": { "color": "#9AA0A6" },

                    "property": { "color": "#8AB4F8" },
                    "tag": { "color": "#EA4335" },
                    "attribute": { "color": "#D977BFFF" },

                    "preproc": { "color": "#F29900" },

                    "title": { "color": "#FFFFFF", "font_weight": 700 }
                }
            }
        }
    ]
}
